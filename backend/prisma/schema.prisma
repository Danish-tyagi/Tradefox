generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  password     String
  balance      Float       @default(100000)
  refreshToken        String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  isVerified          Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orders       Order[]
  portfolio    Portfolio[]
  watchlist    Watchlist[]
  priceAlerts  PriceAlert[]
}

model Stock {
  id            String      @id @default(cuid())
  symbol        String      @unique
  name          String
  currentPrice  Float
  prevClose     Float
  change        Float       @default(0)
  changePercent Float       @default(0)
  sector        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orders        Order[]
  portfolio     Portfolio[]
  watchlist     Watchlist[]
  priceAlerts   PriceAlert[]
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  stockId      String
  type         OrderType
  side         OrderSide
  quantity     Int
  price        Float
  triggerPrice Float?
  status       OrderStatus @default(PENDING)
  filledAt     DateTime?
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id])
  stock        Stock       @relation(fields: [stockId], references: [id])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  stock     Stock    @relation(fields: [stockId], references: [id])

  @@unique([userId, stockId])
}

model PriceAlert {
  id          String      @id @default(cuid())
  userId      String
  stockId     String
  condition   AlertCondition
  targetPrice Float
  triggered   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  triggeredAt DateTime?
  user        User        @relation(fields: [userId], references: [id])
  stock       Stock       @relation(fields: [stockId], references: [id])
}

enum AlertCondition {
  ABOVE
  BELOW
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  stockId     String
  quantity    Int
  avgBuyPrice Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  stock       Stock    @relation(fields: [stockId], references: [id])

  @@unique([userId, stockId])
}

enum OrderType {
  MARKET
  LIMIT
  SL
  SLM
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
}
